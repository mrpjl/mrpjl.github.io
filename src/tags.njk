---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/tags/{{ tag }}/"
layout: layouts/base.njk
---

<h1>{{ tag }}</h1>

{% for post in collections[tag] | reverse %}

<div class="post-card">

  <h2>
    <a href="{{ post.url }}">
      {{ post.data.title }}
    </a>
  </h2>

  <p>
    {{ post.data.description }}
  </p>

</div>

{% endfor %}
