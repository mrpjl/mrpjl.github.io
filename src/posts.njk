---
layout: layouts/base.njk
title: Blog
permalink: /posts/
---

<h1>Blog</h1>

{% for post in collections.posts %}

<div class="post-card">
<h2>
  <a href="{{ post.url }}">
    {{ post.data.title }}
  </a>
</h2>

<p>
  {{ post.data.description }}
</p>

<p>
  {{ post.date | postDate }}
</p>

</div>

{% endfor %}
